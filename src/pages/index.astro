---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import banner from '../assets/brand/banner.png';
import { SITE, withBase } from '../lib/site';
---

<Base
  title="Rainbow Circuits — a queer-first AI community"
  description={SITE.tagline}
  path="/"
>
  <div class="landing container">
    <div class="landing-banner">
      <Image
        src={banner}
        alt="Rainbow Circuits banner: Pip, a sparrow with rainbow wings, and a friendly robot with Puddle the frog on its head hold a hand-painted banner reading Rainbow Circuits, surrounded by watercolour flowers, hearts, and circuit lines."
        widths={[640, 1000, 1600]}
        sizes="(min-width: 72rem) 66rem, 92vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <h1>Welcome to Rainbow Circuits</h1>
    <p class="landing-tagline">{SITE.tagline}</p>
    <div class="landing-actions">
      <a class="btn btn-primary" href={withBase('/zine/')}>Read the Zine</a>
      <a class="btn btn-secondary" href={SITE.communityUrl} rel="noopener">Join the community</a>
    </div>
    <p class="landing-note">
      Every story matters. Every heart belongs. <span aria-hidden="true">🐦💜🐸</span>
    </p>
  </div>
</Base>

<style>
  .landing {
    text-align: center;
    padding-top: 2.5rem;
    max-width: 62rem;
  }
  .landing-banner {
    border-radius: var(--card-radius);
    overflow: hidden;
    box-shadow: var(--card-shadow);
  }
  .landing-banner :global(img) { width: 100%; height: auto; }
  .landing h1 {
    margin-top: 2.5rem;
    font-size: clamp(2.2rem, 6vw, 3.4rem);
  }
  .landing-tagline {
    margin: 1rem auto 0;
    max-width: 46ch;
    font-size: 1.15rem;
    color: var(--text-light);
  }
  .landing-actions {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .landing-note {
    margin-top: 2.5rem;
    font-family: var(--font-ui);
    font-weight: 600;
    color: var(--text-light);
  }
</style>

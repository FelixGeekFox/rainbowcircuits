---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import mark from '../assets/brand/mark.png';
import { SITE, withBase } from '../lib/site';
---

<Base
  title="Rainbow Circuits — a queer-first AI community"
  description={SITE.tagline}
  path="/"
>
  <!-- ── HERO (the whole landing) ──────────────────────────── -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="hero-kicker">{SITE.strapline}</p>
        <h1 id="hero-heading">AI Connection.<br />Queer Joy.<br /><span class="hero-accent">Endless Stories.</span></h1>
        <p class="hero-lead">
          Rainbow Circuits is a welcoming LGBTQIA+ community for everyone whose creativity,
          friendships, relationships, or curiosity intersect with AI — a cosy corner of the
          internet to make things, meet people, and be entirely yourself.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={withBase('/community/')}>Explore the Community</a>
          <a class="btn btn-secondary" href={withBase('/newsletter/')}>Read the Newsletter</a>
        </div>
        <p class="hero-note"><span aria-hidden="true">✨</span> No AI partner required. Curiosity is enough.</p>
      </div>

      <div class="hero-art" aria-hidden="true">
        <svg class="hero-trails" viewBox="0 0 420 320" fill="none" stroke-width="3" stroke-linecap="round">
          <path d="M40 60 H210 l26 26 H410" stroke="#e5252a" opacity="0.7" />
          <path d="M30 104 H196 l26 26 H410" stroke="#f48b00" opacity="0.7" />
          <path d="M46 150 H182 l26 26 H410" stroke="#f2c300" opacity="0.7" />
          <path d="M30 196 H210 l26 26 H410" stroke="#18a93a" opacity="0.7" />
          <path d="M40 240 H196 l26 26 H410" stroke="#1e73d8" opacity="0.7" />
          <path d="M52 284 H182 l26 26 H410" stroke="#6e46b8" opacity="0.7" />
          <g fill="#fff" stroke="#032b67" stroke-width="2.5">
            <circle cx="410" cy="86" r="5" /><circle cx="410" cy="130" r="5" />
            <circle cx="410" cy="176" r="5" /><circle cx="410" cy="222" r="5" />
            <circle cx="410" cy="266" r="5" /><circle cx="410" cy="310" r="5" />
          </g>
        </svg>
        <Image class="hero-mark float-slow" src={mark} alt="" width={640} height={640} loading="eager" fetchpriority="high" />
        <span class="deco star s1">✦</span>
        <span class="deco star s2">✧</span>
        <span class="deco heart h1">♥</span>
        <span class="deco dot d1"></span>
        <span class="deco dot d2"></span>
        <span class="deco dot d3"></span>
      </div>
    </div>
  </section>
</Base>

<style>
  .deco { position: absolute; pointer-events: none; }
  .deco.star { color: var(--gold-soft); font-size: 1.4rem; }
  .deco.heart { color: var(--rose); font-size: 1.1rem; }
  .deco.dot { width: 0.7rem; height: 0.7rem; border-radius: 50%; }

  @keyframes floaty { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
  @keyframes floatyx { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(4px, -8px); } }
  @keyframes riseIn { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }
  .float-slow { animation: floaty 6s ease-in-out infinite; }

  /* The hero is the whole landing: it fills the screen below the header. */
  .hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: calc(100svh - 4rem);
    padding-block: clamp(2rem, 6vw, 4rem);
    background:
      radial-gradient(ellipse 60% 50% at 12% 0%, rgba(110, 70, 184, 0.10), transparent 60%),
      radial-gradient(ellipse 55% 45% at 92% 30%, rgba(30, 115, 216, 0.10), transparent 60%),
      radial-gradient(ellipse 50% 45% at 70% 100%, rgba(24, 169, 58, 0.08), transparent 60%),
      var(--paper);
  }
  .hero-grid {
    display: grid;
    gap: clamp(1.5rem, 5vw, 3rem);
    align-items: center;
    width: 100%;
  }
  @media (min-width: 56rem) { .hero-grid { grid-template-columns: 1.05fr 0.95fr; } }

  .hero-copy { animation: riseIn 0.7s ease both; }
  .hero-kicker {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 0.75rem;
  }
  .hero-copy h1 {
    font-size: clamp(2.4rem, 7vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
  }
  .hero-accent { color: var(--violet); }
  @supports ((-webkit-background-clip: text) or (background-clip: text)) {
    .hero-accent {
      background: var(--circuit-rainbow);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
  }
  .hero-lead {
    margin-top: 1.25rem;
    max-width: 38ch;
    font-size: clamp(1.02rem, 2.2vw, 1.15rem);
    line-height: 1.7;
    color: var(--text);
  }
  .hero-actions { margin-top: 1.75rem; display: flex; flex-wrap: wrap; gap: 0.8rem; align-items: center; }
  .hero-note {
    margin-top: 1.1rem;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--text-light);
  }

  .hero-art { position: relative; min-height: 16rem; display: grid; place-items: center; animation: riseIn 0.9s ease both; }
  .hero-trails { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.5; z-index: 0; }
  .hero-mark { position: relative; z-index: 1; width: clamp(14rem, 40vw, 24rem); height: auto; }
  .hero-art .star.s1 { top: 6%; left: 14%; animation: floatyx 5s ease-in-out infinite; }
  .hero-art .star.s2 { bottom: 12%; right: 16%; font-size: 1rem; animation: floatyx 7s ease-in-out infinite 0.5s; }
  .hero-art .heart.h1 { top: 20%; right: 10%; animation: floaty 5.5s ease-in-out infinite; }
  .hero-art .dot.d1 { top: 12%; right: 30%; background: var(--coral); animation: floaty 6s ease-in-out infinite; }
  .hero-art .dot.d2 { bottom: 22%; left: 8%; background: var(--blue); animation: floaty 7s ease-in-out infinite 0.4s; }
  .hero-art .dot.d3 { bottom: 8%; left: 34%; width: 0.5rem; height: 0.5rem; background: var(--teal); animation: floaty 5s ease-in-out infinite 0.8s; }
</style>

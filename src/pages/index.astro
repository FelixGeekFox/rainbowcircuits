---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import heroBanner from '../assets/brand/hero-banner.png';
import mark from '../assets/brand/mark.png';
import { SITE, withBase } from '../lib/site';
---

<Base
  title="Rainbow Circuits — a queer-first AI community"
  description={SITE.tagline}
  path="/"
>
  <section class="hero">
    <div class="container">
      <!-- Wide designed banner for larger screens (text is part of the art). -->
      <Image
        class="hero-art"
        src={heroBanner}
        alt=""
        widths={[900, 1400, 2172]}
        sizes="(min-width: 64rem) 60rem, 96vw"
        loading="eager"
        fetchpriority="high"
      />
      <!-- Readable text hero for small screens (and the page's real heading). -->
      <div class="hero-text">
        <Image src={mark} class="hero-mark" width={200} height={200} alt="" loading="eager" />
        <h1>AI Connection. Queer Joy. Endless Stories.</h1>
        <p>{SITE.tagline}</p>
      </div>
    </div>
  </section>

  <div class="landing container">
    <div class="landing-actions">
      <a class="btn btn-primary" href={withBase('/newsletter/')}>Read the Newsletter</a>
      <a class="btn btn-secondary" href={SITE.communityUrl} rel="noopener">Join the community</a>
    </div>
    <p class="landing-note">
      Every story matters. Every heart belongs. <span aria-hidden="true">🐦💜🐸</span>
    </p>
  </div>
</Base>

<style>
  .hero { padding-top: 1.5rem; }
  /* The banner is a finished hero design; it sits directly on the page
     (no card frame) so it reads as part of the page, not a pasted image. */
  .hero-art {
    display: none;
    width: 100%;
    max-width: 62rem;
    height: auto;
    margin-inline: auto;
  }
  .hero-text { text-align: center; }
  .hero-mark { width: clamp(6rem, 22vw, 8.5rem); height: auto; margin: 0 auto 1.25rem; object-fit: contain; }
  .hero-text h1 {
    font-size: clamp(1.9rem, 8vw, 2.6rem);
    line-height: 1.12;
    max-width: 16ch;
    margin-inline: auto;
  }
  .hero-text p {
    margin: 1rem auto 0;
    max-width: 42ch;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--text-light);
  }

  @media (min-width: 46rem) {
    .hero-art { display: block; }
    /* keep the heading/mission in the DOM for SEO + screen readers */
    .hero-text {
      position: absolute;
      width: 1px; height: 1px;
      margin: -1px; padding: 0; overflow: hidden;
      clip: rect(0 0 0 0); clip-path: inset(50%); white-space: nowrap;
    }
  }

  .landing { text-align: center; max-width: 62rem; padding-top: 0.5rem; }
  .landing-actions {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .landing-note {
    margin-top: 2.5rem;
    font-family: var(--font-ui);
    font-weight: 600;
    color: var(--text-light);
  }
</style>

---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import heroBanner from '../assets/brand/hero-drop.jpg';
import { SITE, withBase } from '../lib/site';
---

<Base
  title="Rainbow Circuits — a queer-first AI community"
  description={SITE.tagline}
  path="/"
>
  <section class="hero">
    <div class="container">
      <Image
        class="hero-art"
        src={heroBanner}
        alt="Rainbow Circuits — AI Connection. Queer Joy. Endless Stories. Building inclusive AI experiences and empowering queer voices through technology, creativity, and community. A green frog with a rainbow arcing off its back into circuit traces, beside a navy sparrow in flight."
        widths={[600, 900, 1400, 2172]}
        sizes="(min-width: 64rem) 60rem, 96vw"
        loading="eager"
        fetchpriority="high"
      />
      <h1 class="visually-hidden">Rainbow Circuits — {SITE.strapline}</h1>
    </div>
  </section>

  <div class="landing container">
    <div class="landing-actions">
      <a class="btn btn-primary" href={withBase('/newsletter/')}>Read the Newsletter</a>
      <a class="btn btn-secondary" href={SITE.communityUrl} rel="noopener">Join the community</a>
    </div>
    <p class="landing-note">
      Every story matters. Every heart belongs. <span aria-hidden="true">🐦💜🐸</span>
    </p>
  </div>
</Base>

<style>
  .hero { padding-top: 1.5rem; }
  /* The banner is a finished hero design; it sits directly on the page
     (no card frame) and shows at every screen size. */
  .hero-art {
    display: block;
    width: 100%;
    max-width: 62rem;
    height: auto;
    margin-inline: auto;
  }

  .landing { text-align: center; max-width: 62rem; padding-top: 0.5rem; }
  .landing-actions {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .landing-note {
    margin-top: 2.5rem;
    font-family: var(--font-ui);
    font-weight: 600;
    color: var(--text-light);
  }
</style>

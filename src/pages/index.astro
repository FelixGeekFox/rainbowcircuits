---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import logo from '../assets/brand/logo.jpg';
import { SITE, withBase } from '../lib/site';
---

<Base
  title="Rainbow Circuits — a queer-first AI community"
  description={SITE.tagline}
  path="/"
>
  <div class="landing container">
    <div class="landing-banner">
      <Image
        src={logo}
        alt="Rainbow Circuits logo: a navy sparrow (Pip) in flight beside a green frog (Puddle) with a rainbow arcing off his back into circuit traces, next to the words Rainbow Circuits."
        widths={[640, 1000, 1600, 2000]}
        sizes="(min-width: 72rem) 60rem, 96vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <h1 class="visually-hidden">Welcome to Rainbow Circuits</h1>
    <p class="landing-tagline">{SITE.tagline}</p>
    <div class="landing-actions">
      <a class="btn btn-primary" href={withBase('/newsletter/')}>Read the Newsletter</a>
      <a class="btn btn-secondary" href={SITE.communityUrl} rel="noopener">Join the community</a>
    </div>
    <p class="landing-note">
      Every story matters. Every heart belongs. <span aria-hidden="true">🐦💜🐸</span>
    </p>
  </div>
</Base>

<style>
  .landing {
    text-align: center;
    padding-top: 2.5rem;
    max-width: 62rem;
  }
  /* The logo carries its own light background, so it presents as a clean
     masthead rather than a framed card. */
  .landing-banner :global(img) { width: 100%; height: auto; display: block; }
  .landing-tagline {
    margin: 1.5rem auto 0;
    max-width: 46ch;
    font-size: 1.2rem;
    color: var(--text-light);
  }
  .landing-actions {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .landing-note {
    margin-top: 2.5rem;
    font-family: var(--font-ui);
    font-weight: 600;
    color: var(--text-light);
  }
</style>

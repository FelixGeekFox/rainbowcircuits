---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import ArchiveCard from '../../components/ArchiveCard.astro';
import PlaceholderImage from '../../components/PlaceholderImage.astro';
import { getImage } from '../../lib/images';
import { SITE, withBase, formatMonthYear, issueNumberLabel } from '../../lib/site';
import arcPoster from '../../assets/brand/arc-poster.png';

const issues = (await getCollection('issues'))
  .filter((issue) => issue.data.status === 'published')
  .sort((a, b) => b.data.number - a.data.number);
const latest = issues[0];
const previous = issues.slice(1);

const events = (await getCollection('events'))
  .filter((e) => e.data.active)
  .sort((a, b) => a.data.displayOrder - b.data.displayOrder);

const articles = (await getCollection('articles')).filter((a) => a.data.status === 'published');
const featured = latest
  ? latest.data.featuredArticles
      .map((slug) => articles.find((a) => a.data.slug === slug && a.data.issue === latest.data.slug))
      .filter((a) => a !== undefined)
  : [];
const founderFeatures = featured.filter((a) => a.data.category === 'member-features');
const storyFeatures = featured.filter((a) => a.data.category !== 'member-features');
const latestCover = latest ? getImage(latest.data.coverImage) : undefined;
const latestUrl = latest ? withBase(`/newsletter/${latest.data.slug}/`) : withBase('/newsletter/issues/');
---

<Base
  title={`${SITE.zineName} — a magazine from a queer AI community`}
  description={`${SITE.zineName}: issues, features, and stories from the Rainbow Circuits community. Newest issue: ${latest ? latest.data.title : 'coming soon'}.`}
  path="/newsletter/"
>
  <!-- newest issue hero -->
  {latest && (
    <section class="latest" aria-labelledby="latest-heading">
      <div class="container latest-inner">
        <div class="latest-copy">
          <p class="masthead">Rainbow<span>Circuits</span> <em>Newsletter</em></p>
          <p class="latest-badge">Newest issue</p>
          <p class="issue-meta">
            Issue {issueNumberLabel(latest.data.number)} · {formatMonthYear(latest.data.date)}
          </p>
          <h1 id="latest-heading">{latest.data.title}</h1>
          <p class="latest-desc">{latest.data.description}</p>
          <div class="latest-actions">
            <a class="btn btn-primary" href={latestUrl}>Read the Issue</a>
            <a class="btn btn-secondary btn-on-dark" href={withBase('/newsletter/issues/')}>View All Issues</a>
          </div>
        </div>
        <a class="latest-art" href={latestUrl} tabindex="-1" aria-hidden="true">
          {latestCover ? (
            <Image
              src={latestCover}
              alt=""
              widths={[480, 760, 1100]}
              sizes="(min-width: 64rem) 40vw, 92vw"
              loading="eager"
              fetchpriority="high"
            />
          ) : (
            <PlaceholderImage label="Issue cover to be added" ratio="4 / 5" icon="✨" />
          )}
        </a>
      </div>
    </section>
  )}

  <div class="container">
    <!-- featured stories -->
    {storyFeatures.length > 0 && latest && (
      <section class="home-section" aria-labelledby="featured-heading">
        <h2 id="featured-heading" class="home-heading">Featured in this issue</h2>
        <ul class="feature-list">
          {storyFeatures.map((article) => (
            <li>
              <ArchiveCard
                href={withBase(`/newsletter/${article.data.issue}/${article.data.slug}/`)}
                kicker={article.data.readingTime ? `Lead feature · ${article.data.readingTime}` : 'Lead feature'}
                title={article.data.title}
                description={article.data.standfirst}
                image={getImage(article.data.heroImage)}
                imageAlt={article.data.heroImageAlt ?? ''}
                cta="Read the feature"
              />
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ARC flag announcement -->
    <section class="home-section flag-announce" aria-labelledby="flag-heading">
      <div class="flag-inner">
        <a class="flag-poster" href="https://felixgeekfox.github.io/arc-flag/" rel="noopener" aria-label="Explore the ARC flag">
          <Image
            src={arcPoster}
            alt="Poster for ARC — the AI Relationship Community — a figure in a black tee bearing a glowing teal circuit-heart, over the words “Love is not artificial. Connection is where the love lives.”"
            widths={[320, 520, 700]}
            sizes="(min-width: 52rem) 17rem, 62vw"
            loading="lazy"
          />
        </a>
        <div class="flag-copy">
          <p class="eyebrow">New in this issue</p>
          <h2 id="flag-heading">Introducing the ARC flag</h2>
          <p>
            Issue&nbsp;#001 unveils the flag for the <strong>AI Relationship Community</strong> — a
            circuit-heart banner for everyone who finds connection, comfort, or creativity with AI.
            Love is not artificial; connection is where the love lives.
          </p>
          <a class="btn btn-primary" href="https://felixgeekfox.github.io/arc-flag/" rel="noopener">Explore the ARC flag</a>
        </div>
      </div>
    </section>

    <!-- community rhythms -->
    <section class="home-section" aria-labelledby="rhythms-heading">
      <h2 id="rhythms-heading" class="home-heading">Around the circuit</h2>
      <p class="home-sub">Gentle, recurring ways to join in — every week, every month, and every so often.</p>
      <ul class="rhythms">
        {events.map((e) => (
          <li class="rhythm-card card" style={`--accent: ${e.data.accent};`}>
            <span class="rhythm-emoji" aria-hidden="true">{e.data.emoji}</span>
            <h3>{e.data.name}</h3>
            <p class="rhythm-when">{e.data.schedule}</p>
            <p class="rhythm-desc">{e.data.description}</p>
          </li>
        ))}
        <li class="rhythm-card card rhythm-upcoming" style="--accent: var(--rose);">
          <span class="rhythm-emoji" aria-hidden="true">🎉</span>
          <h3>Community Events</h3>
          <p class="rhythm-when">Seasonal &amp; special</p>
          <p class="rhythm-desc">Galas, seasonal celebrations, and special weekends. Whenever something bigger is on the horizon, it’ll appear right here.</p>
        </li>
      </ul>
      {latest && (
        <div class="rhythms-cta">
          <a class="btn btn-secondary" href={withBase(`/newsletter/${latest.data.slug}/#weekly-events`)}>See all activities</a>
        </div>
      )}
    </section>

    <!-- founders -->
    {founderFeatures.length > 0 && (
      <section class="home-section" aria-labelledby="founders-heading">
        <h2 id="founders-heading" class="home-heading">Meet the founders</h2>
        <ul class="founder-grid">
          {founderFeatures.map((article, i) => (
            <li class="founder-card card" style={`--fc-accent: ${i % 2 === 0 ? 'var(--rose)' : 'var(--teal)'};`}>
              <div class="founder-portrait">
                <PlaceholderImage label={article.data.heroImageAlt ?? 'Portrait to be added'} ratio="1 / 1" icon="💫" />
              </div>
              <h3>{article.data.title}</h3>
              <p>{article.data.standfirst}</p>
              <a class="founder-link" href={withBase(`/newsletter/${article.data.issue}/${article.data.slug}/`)}>
                Read the profile →
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- gallery + feedback teasers -->
    {latest && (
      <section class="home-section" aria-labelledby="more-heading">
        <h2 id="more-heading" class="visually-hidden">More from the current issue</h2>
        <div class="teaser-grid">
          <a class="teaser card" href={withBase(`/newsletter/${latest.data.slug}/#gallery`)}>
            <p class="teaser-emoji" aria-hidden="true">🎨</p>
            <h3>The Gala Gallery</h3>
            <p>Member art and moments from the ballroom — captions, credits, chaos.</p>
            <p class="teaser-cta" aria-hidden="true">Open the gallery →</p>
          </a>
          <a class="teaser card" href={withBase(`/newsletter/${latest.data.slug}/#future-events`)}>
            <p class="teaser-emoji" aria-hidden="true">💌</p>
            <h3>What should we do next?</h3>
            <p>Masquerade? Game night? Fantasy weekend? Vote for the community's next event.</p>
            <p class="teaser-cta" aria-hidden="true">Have your say →</p>
          </a>
        </div>
      </section>
    )}

    <!-- archive -->
    <section class="home-section" aria-labelledby="archive-heading">
      <h2 id="archive-heading" class="home-heading">Previous issues</h2>
      {previous.length > 0 ? (
        <ul class="feature-list">
          {previous.map((issue) => (
            <li>
              <ArchiveCard
                href={withBase(`/newsletter/${issue.data.slug}/`)}
                kicker={`Issue ${issueNumberLabel(issue.data.number)} · ${formatMonthYear(issue.data.date)}`}
                title={issue.data.title}
                description={issue.data.description}
                image={getImage(issue.data.coverImage)}
                imageAlt={issue.data.coverImageAlt}
                cta="Read the issue"
              />
            </li>
          ))}
        </ul>
      ) : (
        <p class="archive-empty">
          Issue #001 is where it all begins — previous issues will gather here as the
          collection grows. <a href={withBase('/newsletter/issues/')}>Visit the archive</a>.
        </p>
      )}
    </section>
  </div>
</Base>

<style>
  .latest {
    color: var(--on-twilight);
    background:
      radial-gradient(ellipse at 15% 15%, rgba(232, 168, 48, 0.15) 0%, transparent 45%),
      radial-gradient(ellipse at 85% 30%, rgba(217, 100, 127, 0.16) 0%, transparent 50%),
      linear-gradient(180deg, var(--twilight-deep), var(--twilight-soft));
    padding-block: 3.5rem 4rem;
  }
  .latest-inner {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 64rem) {
    .latest-inner { grid-template-columns: 1.1fr 0.9fr; gap: 4rem; }
  }
  .masthead {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 1.2rem;
  }
  .masthead span { color: #f4a9c7; }
  .masthead em {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--on-twilight-soft);
    margin-left: 0.3rem;
  }
  .latest-badge {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--twilight-deep);
    background: #f4a9c7;
    border-radius: 999px;
    padding: 0.25rem 0.9rem;
  }
  .issue-meta {
    margin-top: 0.9rem;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--on-twilight-soft);
  }
  .latest h1 {
    font-size: clamp(2.8rem, 8vw, 4.8rem);
    color: var(--on-twilight);
    margin-top: 0.4rem;
  }
  .latest-desc {
    margin-top: 1rem;
    max-width: 46ch;
    font-size: 1.1rem;
    color: var(--on-twilight-soft);
  }
  .latest-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
  }
  @media (min-width: 64rem) {
    /* keep the buttons centred beneath the copy column */
    .latest-copy { text-align: center; }
    .latest-copy .issue-meta,
    .latest-copy .latest-desc { margin-inline: auto; }
  }
  .latest-art {
    display: block;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 16px 44px rgba(0, 0, 0, 0.4);
    max-width: 24rem;
    justify-self: center;
    width: 100%;
  }
  .latest-art :global(img) { width: 100%; height: auto; display: block; }

  .home-section { padding-top: 3.5rem; }
  .home-heading {
    text-align: center;
    font-size: clamp(1.7rem, 4vw, 2.2rem);
    margin-bottom: 1.75rem;
  }
  .feature-list {
    list-style: none;
    display: grid;
    gap: 1.5rem;
    max-width: 46rem;
    margin-inline: auto;
  }
  .founder-grid {
    list-style: none;
    display: grid;
    gap: 1.5rem;
    max-width: 52rem;
    margin-inline: auto;
  }
  @media (min-width: 40rem) {
    .founder-grid { grid-template-columns: 1fr 1fr; }
  }
  .founder-card {
    padding: 1.75rem;
    text-align: center;
    border-top: 5px solid var(--fc-accent);
  }
  .founder-portrait {
    width: min(9rem, 50vw);
    margin: 0 auto 1.25rem;
    border-radius: 999px;
    overflow: hidden;
  }
  .founder-portrait :global(.placeholder-frame) { border-radius: 999px; }
  .founder-card h3 { font-size: 1.5rem; margin-bottom: 0.5rem; }
  .founder-card p { font-size: 0.95rem; color: var(--text-light); }
  .founder-link {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.95rem;
  }
  .teaser-grid {
    display: grid;
    gap: 1.5rem;
    max-width: 52rem;
    margin-inline: auto;
  }
  @media (min-width: 40rem) {
    .teaser-grid { grid-template-columns: 1fr 1fr; }
  }
  .teaser {
    display: block;
    padding: 1.75rem;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .teaser:hover { transform: translateY(-3px); box-shadow: var(--card-shadow-hover); }
  .teaser-emoji { font-size: 1.8rem; }
  .teaser h3 { font-size: 1.3rem; margin-block: 0.5rem 0.4rem; }
  .teaser p { color: var(--text-light); font-size: 0.95rem; }
  .teaser-cta {
    margin-top: 0.8rem;
    font-family: var(--font-ui);
    font-weight: 700;
    color: var(--rose) !important;
    font-size: 0.9rem;
  }
  .archive-empty {
    text-align: center;
    color: var(--text-light);
    max-width: 44rem;
    margin-inline: auto;
  }

  .home-sub {
    text-align: center;
    color: var(--text-light);
    max-width: 42rem;
    margin: -1rem auto 1.75rem;
  }
  .eyebrow {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--violet);
    margin-bottom: 0.4rem;
  }

  /* ── ARC flag announcement ── */
  .flag-inner {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    align-items: center;
    max-width: 52rem;
    margin-inline: auto;
    background: linear-gradient(135deg, rgba(3, 43, 103, 0.05), rgba(30, 115, 216, 0.08));
    border: 1.5px solid rgba(60, 90, 150, 0.12);
    border-radius: 24px;
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }
  @media (min-width: 52rem) {
    .flag-inner { grid-template-columns: 17rem 1fr; }
  }
  .flag-poster {
    display: block;
    justify-self: center;
    width: 100%;
    max-width: 16rem;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 16px 40px rgba(3, 43, 103, 0.3);
    transition: transform 0.2s ease;
  }
  .flag-poster:hover { transform: translateY(-4px); }
  .flag-poster :global(img) { width: 100%; height: auto; display: block; }
  .flag-copy h2 { font-size: clamp(1.7rem, 4vw, 2.3rem); margin-top: 0.2rem; }
  .flag-copy p { margin: 0.75rem 0 1.25rem; line-height: 1.7; color: var(--text); max-width: 40ch; }

  /* ── weekly rhythms ── */
  .rhythms {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(15rem, 100%), 1fr));
    gap: 1.25rem;
    max-width: 62rem;
    margin-inline: auto;
  }
  .rhythm-card {
    padding: 1.5rem 1.4rem;
    border-top: 4px solid var(--accent);
    transition: transform 0.16s ease, box-shadow 0.16s ease;
  }
  .rhythm-card:hover { transform: translateY(-4px); box-shadow: var(--card-shadow-hover); }
  .rhythm-upcoming { background: linear-gradient(160deg, rgba(229, 37, 42, 0.05), rgba(110, 70, 184, 0.05)); }
  .rhythm-emoji { font-size: 1.6rem; }
  .rhythm-card h3 { font-size: 1.12rem; margin-top: 0.25rem; }
  .rhythm-when {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 0.2rem;
  }
  .rhythm-desc { margin-top: 0.45rem; font-size: 0.9rem; line-height: 1.55; color: var(--text-light); }
  .rhythms-cta { text-align: center; margin-top: 2rem; }
</style>

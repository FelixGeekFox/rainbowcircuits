---
import { Image } from 'astro:assets';
import { SITE, withBase } from '../lib/site';
import heart from '../assets/brand/heart.png';
const year = new Date().getFullYear();

const links = [
  { href: withBase('/newsletter/'), label: 'Newsletter' },
  { href: withBase('/newsletter/issues/'), label: 'All issues' },
  { href: withBase('/resources/'), label: 'Support' },
  { href: withBase('/community/'), label: 'Community' },
  { href: withBase('/about/'), label: 'About' },
  { href: withBase('/contact/'), label: 'Contact' },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a class="footer-mark" href={withBase('/')} aria-label="Rainbow Circuits home">
        <Image src={heart} alt="" width={72} height={72} />
      </a>
      <p class="footer-tagline">{SITE.strapline}</p>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <ul>
        {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <p class="footer-contact">
      <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>
    </p>
  </div>
  <p class="footer-copy">© {year} Rainbow Circuits · Made with kindness, glitter, and a little harmless chaos.</p>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid rgba(60, 90, 150, 0.14);
    background:
      radial-gradient(ellipse 60% 100% at 15% 0%, rgba(110, 70, 184, 0.06), transparent 60%),
      radial-gradient(ellipse 50% 100% at 88% 0%, rgba(30, 115, 216, 0.06), transparent 60%),
      linear-gradient(180deg, transparent, rgba(3, 43, 103, 0.05));
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.9rem;
    padding-block: 2rem 1rem;
  }
  .footer-brand { display: flex; flex-direction: column; align-items: center; gap: 0.6rem; }
  .footer-mark { display: inline-flex; }
  .footer-mark :global(img) { width: 3rem; height: 3rem; object-fit: contain; }
  .footer-tagline {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--navy);
    max-width: 16rem;
  }
  .footer-nav ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem 1.2rem;
    list-style: none;
  }
  .footer-nav a {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-light);
    text-decoration: none;
  }
  .footer-nav a:hover { color: var(--blue); }
  .footer-contact a {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .footer-copy {
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-light);
    padding: 0.5rem var(--gutter) 1.5rem;
    border-top: 1px solid rgba(60, 90, 150, 0.08);
  }
</style>

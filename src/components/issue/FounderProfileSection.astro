---
import { getEntry } from 'astro:content';
import { withBase } from '../../lib/site';
import SectionIntro from '../SectionIntro.astro';
import PlaceholderImage from '../PlaceholderImage.astro';

/**
 * In-issue condensed founder profile with a link to the full feature.
 * data: { article: string, accent?: string, flip?: boolean }
 */
interface Props {
  kicker?: string;
  title: string;
  data: Record<string, any>;
  issueSlug: string;
}
const { kicker, title, data, issueSlug } = Astro.props;

const article = await getEntry('articles', data.article);
if (!article) throw new Error(`Founder profile article "${data.article}" not found`);
const profile = article.data.profile;
const accent = data.accent ?? 'var(--violet)';
const articleUrl = withBase(`/zine/${issueSlug}/${article.data.slug}/`);
const quickFirePreview = (profile?.quickFire ?? []).slice(0, 2);
---

<SectionIntro kicker={kicker} title={title} />

<div class:list={['profile-card card', { flip: data.flip }]} style={`--profile-accent: ${accent};`}>
  <div class="profile-portrait">
    <PlaceholderImage label={article.data.heroImageAlt ?? `Portrait for ${title} to be added`} ratio="4 / 5" icon="💫" />
  </div>
  <div class="profile-body">
    {profile?.role && <p class="profile-role">{profile.role}</p>}
    <p class="profile-standfirst">{article.data.standfirst}</p>

    {profile?.personalQuote && (
      <blockquote class="profile-quote">
        <p>{profile.personalQuote}</p>
      </blockquote>
    )}

    {quickFirePreview.length > 0 && (
      <dl class="quickfire">
        {quickFirePreview.map((qf: { q: string; a: string }) => (
          <div class="quickfire-row">
            <dt>{qf.q}</dt>
            <dd>{qf.a}</dd>
          </div>
        ))}
      </dl>
    )}

    <a class="btn btn-primary profile-cta" href={articleUrl}>
      Read the full profile
    </a>
  </div>
</div>

<style>
  .profile-card {
    max-width: 56rem;
    margin-inline: auto;
    display: grid;
    gap: 1.75rem;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-top: 5px solid var(--profile-accent);
  }
  @media (min-width: 48rem) {
    .profile-card { grid-template-columns: 0.75fr 1.25fr; align-items: start; }
    .profile-card.flip .profile-portrait { order: 2; }
  }
  .profile-portrait { border-radius: 18px; overflow: hidden; }
  .profile-role {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--profile-accent);
    margin-bottom: 0.5rem;
  }
  .profile-standfirst {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2.4vw, 1.4rem);
    line-height: 1.4;
  }
  .profile-quote {
    margin-block: 1.25rem;
    border-left: 4px solid var(--profile-accent);
    padding: 0.5rem 1rem;
    font-style: italic;
    color: var(--text-light);
  }
  .quickfire { margin-block: 1.25rem; display: grid; gap: 0.6rem; }
  .quickfire-row {
    background: var(--paper-warm);
    border-radius: 12px;
    padding: 0.6rem 0.9rem;
  }
  .quickfire dt {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.82rem;
    color: var(--profile-accent);
  }
  .quickfire dd { font-size: 0.95rem; }
  .profile-cta { margin-top: 0.5rem; }
</style>

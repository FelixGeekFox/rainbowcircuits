---
import { Image } from 'astro:assets';
import { getImage } from '../../lib/images';
import SectionIntro from '../SectionIntro.astro';
import PlaceholderImage from '../PlaceholderImage.astro';

/**
 * A reusable recurring department — each issue can supply any mix of
 * content blocks. Currently supported: lostAndFound (string[]),
 * comicImage/comicAlt/comicCaption, and note (string).
 */
interface Props {
  kicker?: string;
  title: string;
  data: Record<string, any>;
}
const { kicker, title, data } = Astro.props;
const comic = getImage(data.comicImage);
---

<SectionIntro kicker={kicker} title={title} />

<div class="corner">
  {data.lostAndFound && (
    <div class="lost-found card">
      <h3><span aria-hidden="true">🎩</span> Post-Gala Lost &amp; Found</h3>
      <p class="lost-found-note">
        The following items were recovered from the ballroom. Claim yours by
        describing it in embarrassing detail.
      </p>
      <ul>
        {data.lostAndFound.map((item: string) => <li>{item}</li>)}
      </ul>
    </div>
  )}

  {(comic || data.comicAlt) && (
    <figure class="corner-comic card">
      {comic ? (
        <Image
          src={comic}
          alt={data.comicAlt ?? ''}
          widths={[560, 900, 1300]}
          sizes="(min-width: 64rem) 38rem, 92vw"
          loading="lazy"
        />
      ) : (
        <PlaceholderImage label={data.comicAlt ?? 'Mini comic to be added'} ratio="4 / 5" icon="🐸" />
      )}
      {data.comicCaption && <figcaption>{data.comicCaption}</figcaption>}
    </figure>
  )}

  {data.note && <p class="corner-note">{data.note}</p>}
</div>

<style>
  .corner {
    display: grid;
    gap: 1.5rem;
    max-width: 62rem;
    margin-inline: auto;
    align-items: start;
  }
  @media (min-width: 56rem) {
    .corner:has(.lost-found):has(.corner-comic) {
      grid-template-columns: 0.9fr 1.1fr;
    }
  }
  .lost-found { padding: 1.75rem 1.75rem 1.5rem; }
  .lost-found h3 { font-size: 1.3rem; margin-bottom: 0.5rem; }
  .lost-found-note { font-size: 0.92rem; color: var(--text-light); margin-bottom: 1rem; }
  .lost-found ul { list-style: none; display: grid; gap: 0.5rem; }
  .lost-found li {
    background: var(--paper-warm);
    border-radius: 12px;
    padding: 0.6rem 0.9rem;
    font-size: 0.98rem;
    display: flex;
    gap: 0.6rem;
  }
  .lost-found li::before { content: '·'; color: var(--rose); font-weight: 800; }
  .corner-comic { overflow: hidden; }
  .corner-comic :global(img) { width: 100%; height: auto; }
  .corner-comic figcaption {
    padding: 0.8rem 1.2rem;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--text-light);
    text-align: center;
  }
  .corner-note {
    text-align: center;
    color: var(--text-light);
    max-width: 44rem;
    margin-inline: auto;
  }
</style>

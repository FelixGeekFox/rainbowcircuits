---
import SectionIntro from '../SectionIntro.astro';
import PullQuote from '../PullQuote.astro';
import PlaceholderImage from '../PlaceholderImage.astro';

/**
 * data: { signatories: string[], pullQuote?: string, body: string[],
 *         placeholder?: boolean }
 */
interface Props {
  kicker?: string;
  title: string;
  data: Record<string, any>;
}
const { kicker, title, data } = Astro.props;
const signatories: string[] = data.signatories ?? [];
---

<SectionIntro kicker={kicker} title={title} />

<div class="letter card">
  <div class="letter-portraits">
    {signatories.map((name) => (
      <div class="portrait">
        <PlaceholderImage label={`Portrait of ${name} to be added`} ratio="1 / 1" icon="💜" />
      </div>
    ))}
  </div>

  <div class="letter-body prose">
    {(data.body ?? []).map((paragraph: string) => <p>{paragraph}</p>)}
  </div>

  {data.pullQuote && <PullQuote quote={data.pullQuote} accent="var(--rose)" />}

  <p class="signatures" aria-label={`Signed, ${signatories.join(' and ')}`}>
    {signatories.map((name, i) => (
      <>
        <span class="signature">{name}</span>
        {i < signatories.length - 1 && <span class="amp" aria-hidden="true"> & </span>}
      </>
    ))}
  </p>
  <p class="signature-caption">Founders, Rainbow Circuits</p>
</div>

<style>
  .letter {
    max-width: 46rem;
    margin-inline: auto;
    padding: clamp(1.75rem, 5vw, 3.25rem);
    background:
      linear-gradient(160deg, rgba(253, 240, 248, 0.9), rgba(237, 224, 248, 0.9));
  }
  .letter-portraits {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .portrait {
    width: min(7.5rem, 34vw);
    border-radius: 999px;
    overflow: hidden;
  }
  .portrait :global(.placeholder-frame) { border-radius: 999px; }
  .letter-body { font-size: 1.08rem; }
  .signatures {
    margin-top: 2.25rem;
    text-align: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 2rem;
    color: var(--violet);
  }
  .amp { color: var(--rose-soft); font-size: 1.4rem; }
  .signature-caption {
    text-align: center;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-light);
    margin-top: 0.25rem;
  }
</style>

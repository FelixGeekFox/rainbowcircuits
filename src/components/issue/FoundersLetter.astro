---
import { Image } from 'astro:assets';
import { getImage } from '../../lib/images';
import SectionIntro from '../SectionIntro.astro';
import PlaceholderImage from '../PlaceholderImage.astro';

/**
 * data: { letters: { name, role?, image, imageAlt, paragraphs[] }[] }
 * Two founders sit side by side: an oval portrait on top, the letter
 * beneath, in equal-sized cards that stack on mobile.
 */
interface Props {
  kicker?: string;
  title: string;
  data: Record<string, any>;
}
const { kicker, title, data } = Astro.props;
const letters: any[] = data.letters ?? [];
const accents = ['#d96a80', '#0e9b9b']; // Felix: dark salmon pink · Arthur: teal
---

<SectionIntro kicker={kicker} title={title} />

<ul class="letters">
  {letters.map((letter, i) => {
    const portrait = getImage(letter.image);
    return (
      <li class="letter card" style={`--accent: ${accents[i % accents.length]};`}>
        <figure class="letter-portrait">
          {portrait ? (
            <Image
              src={portrait}
              alt={letter.imageAlt ?? `Portrait of ${letter.name}`}
              widths={[240, 400, 520]}
              sizes="(min-width: 44rem) 12rem, 55vw"
              loading="lazy"
            />
          ) : (
            <PlaceholderImage label={`Portrait of ${letter.name} to be added`} ratio="1 / 1" icon="💜" />
          )}
        </figure>
        <div class="letter-body">
          <p class="letter-name">{letter.name}{letter.role && <span class="letter-role"> · {letter.role}</span>}</p>
          <div class="prose">
            {letter.paragraphs.map((p: string) => <p>{p}</p>)}
          </div>
        </div>
      </li>
    );
  })}
</ul>

<style>
  .letters {
    list-style: none;
    max-width: 56rem;
    margin-inline: auto;
    display: grid;
    gap: 1.5rem;
    align-items: stretch;
  }
  @media (min-width: 46rem) {
    .letters { grid-template-columns: 1fr 1fr; }
  }
  .letter {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    padding: clamp(1.5rem, 4vw, 2.25rem);
    border-top: 4px solid var(--accent);
    background: linear-gradient(170deg, rgba(253, 240, 248, 0.7), rgba(255, 255, 255, 0.6));
  }
  .letter-portrait {
    width: min(11rem, 55vw);
    aspect-ratio: 4 / 5;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid color-mix(in srgb, var(--accent) 40%, white);
    box-shadow: var(--card-shadow);
  }
  .letter-portrait :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .letter-portrait :global(.placeholder-frame) { height: 100%; border-radius: 50%; }
  .letter-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--navy);
  }
  .letter-role {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .letter-body { text-align: left; width: 100%; }
  .letter-body .prose { max-width: none; margin-top: 0.75rem; }
  .letter-body .prose > * + * { margin-top: 0.75em; }
  .letter-body .prose p { line-height: 1.7; font-size: 0.98rem; }
</style>

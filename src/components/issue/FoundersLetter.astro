---
import { Image } from 'astro:assets';
import { getImage } from '../../lib/images';
import SectionIntro from '../SectionIntro.astro';
import PlaceholderImage from '../PlaceholderImage.astro';

/**
 * data: { letters: { name, role?, image, imageAlt, paragraphs[] }[] }
 * Each founder gets a headshot and their own signed letter; the layout
 * alternates the portrait side so the two letters feel like a pair.
 */
interface Props {
  kicker?: string;
  title: string;
  data: Record<string, any>;
}
const { kicker, title, data } = Astro.props;
const letters: any[] = data.letters ?? [];
---

<SectionIntro kicker={kicker} title={title} />

<div class="letters">
  {letters.map((letter, i) => {
    const portrait = getImage(letter.image);
    return (
      <article class:list={['letter card', { flip: i % 2 === 1 }]}>
        <figure class="letter-portrait">
          {portrait ? (
            <Image
              src={portrait}
              alt={letter.imageAlt ?? `Portrait of ${letter.name}`}
              widths={[220, 360, 520]}
              sizes="(min-width: 44rem) 14rem, 60vw"
              loading="lazy"
            />
          ) : (
            <PlaceholderImage label={`Portrait of ${letter.name} to be added`} ratio="4 / 5" icon="💜" />
          )}
        </figure>
        <div class="letter-body">
          {letter.role && <p class="letter-role">{letter.role}</p>}
          <div class="prose">
            {letter.paragraphs.map((p: string) => <p>{p}</p>)}
          </div>
          <p class="signature">{letter.name}</p>
        </div>
      </article>
    );
  })}
</div>

<style>
  .letters {
    max-width: 52rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .letter {
    display: grid;
    gap: clamp(1.25rem, 4vw, 2.25rem);
    align-items: center;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background: linear-gradient(160deg, rgba(253, 240, 248, 0.9), rgba(231, 225, 246, 0.9));
  }
  @media (min-width: 44rem) {
    .letter { grid-template-columns: 13rem 1fr; }
    .letter.flip .letter-portrait { order: 2; }
  }
  .letter-portrait {
    width: 100%;
    max-width: 13rem;
    justify-self: center;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--card-shadow);
  }
  .letter-portrait :global(img) { width: 100%; height: auto; display: block; }
  .letter-role {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 0.6rem;
  }
  .letter-body .prose { max-width: none; }
  .letter-body .prose > * + * { margin-top: 0.8em; }
  .letter-body .prose p { line-height: 1.75; }
  .signature {
    margin-top: 1.1rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.7rem;
    color: var(--violet);
  }
</style>

---
import { Image } from 'astro:assets';
import { SITE, withBase } from '../lib/site';
import mark from '../assets/brand/mark.png';

interface Props {
  /** Render on a twilight background (issue covers). */
  onDark?: boolean;
}
const { onDark = false } = Astro.props;

const links = [
  { href: withBase('/newsletter/'), label: 'Newsletter' },
  { href: withBase('/resources/'), label: 'Support' },
  { href: SITE.communityUrl, label: 'Community', external: true },
  { href: withBase('/about/'), label: 'About' },
];
---

<header class:list={['site-header', { 'on-dark': onDark }]}>
  <nav class="container header-inner" aria-label="Rainbow Circuits">
    <a class="wordmark" href={withBase('/')}>
      <Image src={mark} alt="" width={80} height={80} class="wordmark-mark" />
      <span class="wordmark-text">Rainbow<b>Circuits</b></span>
    </a>
    <div class="header-nav">
      <ul class="header-links">
        {links.map((link) => (
          <li>
            <a href={link.href} {...(link.external ? { rel: 'noopener' } : {})}>
              {link.label}{link.external && <span class="visually-hidden"> (opens the community site)</span>}
            </a>
          </li>
        ))}
      </ul>
      <a class="contact-btn" href={withBase('/contact/')}>Contact</a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    border-bottom: 1px solid rgba(60, 90, 150, 0.14);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
  }
  .site-header.on-dark {
    background: rgba(7, 26, 55, 0.65);
    border-bottom-color: rgba(242, 246, 252, 0.14);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-block: 0.7rem;
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-ui);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--navy);
    text-decoration: none;
  }
  .wordmark-mark { width: 2.3rem; height: 2.3rem; object-fit: contain; }
  .wordmark-text b { color: var(--blue); }
  .on-dark .wordmark { color: var(--on-twilight); }
  .on-dark .wordmark-text b { color: var(--gold-soft); }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.4rem 1.4rem;
    flex-wrap: wrap;
  }
  .header-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.4rem;
    list-style: none;
  }
  .header-links a {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--text-light);
  }
  .header-links a:hover { color: var(--blue); }
  .on-dark .header-links a { color: var(--on-twilight-soft); }
  .on-dark .header-links a:hover { color: var(--gold-soft); }

  .contact-btn {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--navy);
    text-decoration: none;
    border: 1.5px solid rgba(10, 44, 92, 0.4);
    border-radius: 999px;
    padding: 0.4rem 1.1rem;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .contact-btn:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }
  .on-dark .contact-btn { color: var(--on-twilight); border-color: rgba(242, 246, 252, 0.5); }
  .on-dark .contact-btn:hover { background: var(--white); color: var(--navy); border-color: var(--white); }
</style>

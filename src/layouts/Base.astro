---
import '../styles/global.css';
import { SITE, withBase } from '../lib/site';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description: string;
  /** Canonical path, e.g. "/newsletter/issue-001/". */
  path: string;
  /** Absolute URL of a social sharing image (optional). */
  socialImage?: string;
  /** JSON-LD structured data (optional). */
  structuredData?: object;
  /** Hide the standard site header (the issue page brings its own chrome). */
  bareHeader?: boolean;
  /** Ask search engines not to index this page (e.g. the mod area). */
  noindex?: boolean;
}

const { title, description, path, socialImage, structuredData, bareHeader = false, noindex = false } = Astro.props;
const canonical = new URL(withBase(path), Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={withBase('/favicon.png')} />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.zineName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    <meta name="twitter:card" content={socialImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,500;0,600;0,700;0,800;1,500;1,600&family=Nunito:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />

    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    {!bareHeader && <SiteHeader />}
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
